body
  background: transparent !important

#l_body
  background: transparent

.parallax-mirror
  z-index: -1 !important
  pointer-events: none

.cover-wrapper .cover-body
  color: #fff
  text-shadow: 0 2px 8px rgba(0, 0, 0, .65), 0 1px 2px rgba(0, 0, 0, .8)

.cover-wrapper .cover-body .title
  color: #fff
  font-weight: 500
  text-shadow: 0 3px 12px rgba(0, 0, 0, .72), 0 1px 3px rgba(0, 0, 0, .9)

.cover-wrapper.search .bottom .menu .list-h a
  color: #fff2c2 !important
  opacity: 1
  -webkit-opacity: 1
  -moz-opacity: 1
  font-weight: 600
  text-shadow: 0 2px 8px rgba(0, 0, 0, .82), 0 1px 2px rgba(0, 0, 0, .95)

.cover-wrapper.search .bottom .menu .list-h a p
  color: #fff2c2 !important
  font-weight: 600
  text-shadow: 0 2px 8px rgba(0, 0, 0, .82), 0 1px 2px rgba(0, 0, 0, .95)

.cover-wrapper.search .bottom .menu .list-h a:hover,
.cover-wrapper.search .bottom .menu .list-h a.active,
.cover-wrapper.search .bottom .menu .list-h a:active
  color: #fff !important
  border-bottom-color: #fff2c2 !important

.cover-wrapper.search .bottom .menu .list-h a:hover p,
.cover-wrapper.search .bottom .menu .list-h a.active p,
.cover-wrapper.search .bottom .menu .list-h a:active p
  color: #fff !important

.cover-wrapper .m_search .input
  color: #4a413b
  text-shadow: none
